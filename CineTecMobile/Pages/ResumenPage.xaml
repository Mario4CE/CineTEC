<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CineTecMobile.Pages.ResumenPage"
             Title="Resumen de Compra">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Encabezado -->
            <Label Text="Factura de Compra"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#2c3e50"/>

            <!-- Número de Factura -->
            <Frame BorderColor="#ecf0f1" Padding="15" CornerRadius="10">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Número de Factura:"
                           FontAttributes="Bold"
                           FontSize="14"
                           TextColor="Black"/>
                    <Label x:Name="NumeroFacturaLabel"
                           FontSize="16"
                           TextColor="#3498db"/>
                    <Label Text="Fecha:"
                           FontAttributes="Bold"
                           FontSize="14"
                           Margin="0,10,0,0"
                           TextColor="Black"/>
                    <Label x:Name="FechaLabel"
                           FontSize="14"
                           TextColor="Black"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Detalles de la Película -->
            <Frame BorderColor="#ecf0f1" Padding="15" CornerRadius="10">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Detalles de la Película:"
                           FontAttributes="Bold"
                           FontSize="16"
                           TextColor="#2c3e50"/>
                    <Label x:Name="PeliculaLabel"
                           FontSize="14"
                           TextColor="Black"/>
                    <Label x:Name="CineLabel"
                           FontSize="14"
                           TextColor="Black"/>
                    <Label x:Name="FechaHoraLabel"
                           FontSize="14"
                           TextColor="Black"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Asientos Seleccionados -->
            <Frame BorderColor="#ecf0f1" Padding="15" CornerRadius="10">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Asientos Seleccionados:"
                           FontAttributes="Bold"
                           FontSize="16"
                           TextColor="Black"/>
                    <Label x:Name="AsientosLabel"
                           FontSize="14"
                           LineBreakMode="WordWrap"
                           TextColor="Black"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Resumen de Pago -->
            <Frame BorderColor="#27ae60" Padding="15" CornerRadius="10" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Resumen de Pago:"
                           FontAttributes="Bold"
                           FontSize="16"
                           TextColor="#27ae60"/>
                    
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                        <Label Text="Cantidad de Asientos:"
                               FontSize="14"
                               TextColor="Black"/>
                        <Label x:Name="CantidadLabel"
                               FontSize="14"
                               Grid.Column="1"
                               HorizontalTextAlignment="End"
                               TextColor="Black"/>

                        <Label Text="Precio Unitario:"
                               FontSize="14"
                               Grid.Row="1"
                               TextColor="Black"/>
                        <Label x:Name="PrecioUnitarioLabel"
                               FontSize="14"
                               Grid.Row="1"
                               Grid.Column="1"
                               HorizontalTextAlignment="End"
                               TextColor="Black"/>

                        <Label Text="TOTAL:"
                               FontAttributes="Bold"
                               FontSize="16"
                               Grid.Row="2"
                               TextColor="Black"/>
                        <Label x:Name="TotalLabel"
                               FontAttributes="Bold"
                               FontSize="18"
                               TextColor="#27ae60"
                               Grid.Row="2"
                               Grid.Column="1"
                               HorizontalTextAlignment="End"
                               />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Estado -->
            <Frame BorderColor="#f39c12" Padding="15" CornerRadius="10" BackgroundColor="#fef5e7">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Estado:"
                           FontAttributes="Bold"
                           FontSize="14"
                           TextColor="Black"/>
                    <Label x:Name="EstadoLabel"
                           FontSize="14"
                           TextColor="#f39c12"/>
                    <Label Text="Pendiente de confirmación en el cine"
                           FontSize="12"
                           TextColor="Black"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Botones -->
            <VerticalStackLayout Spacing="10" Margin="0,20,0,0">
                <Button Text="Confirmar Compra"
                        BackgroundColor="#27ae60"
                        TextColor="White"
                        Clicked="OnConfirmarClicked"
                        FontAttributes="Bold"/>

                <Button Text="Descargar Factura"
                        BackgroundColor="#3498db"
                        TextColor="White"
                        Clicked="OnDescargarClicked"
                        FontAttributes="Bold"/>

                <Button Text="Volver al Menú"
                        BackgroundColor="#95a5a6"
                        TextColor="White"
                        Clicked="OnVolverMenuClicked"
                        FontAttributes="Bold"/>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
